// Copy this file to secrets.gradle and fill in your real credentials.
// secrets.gradle is gitignored — never commit real credentials.
android {
    defaultConfig {
        buildConfigField "String", "IGDB_CLIENT_ID",     '"YOUR_TWITCH_CLIENT_ID"'
        buildConfigField "String", "IGDB_CLIENT_SECRET", '"YOUR_TWITCH_CLIENT_SECRET"'
    }
}
